        {
          "name": "Crear sucursal",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Sucursal Central\",\n  \"nombreComuna\": \"Santiago\",\n  \"direccionFisica\": \"Av. Libertador 1234\",\n  \"telefonoContacto\": \"+56221234567\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/sucursales", "host": ["{{baseUrl}}"], "path": ["api","v1","sucursales"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var j;",
                  "try { j = pm.response.json(); } catch (e) { j = null; }",
                  "if (j && j.id !== undefined && j.id !== null) pm.collectionVariables.set(\"idSucursal\", j.id);",
                  "pm.test(\"status ok\", function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar sucursales",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/sucursales", "host": ["{{baseUrl}}"], "path": ["api","v1","sucursales"] }
