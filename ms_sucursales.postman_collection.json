{
  "info": {
    "name": "ms_sucursales",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "SIVEBO ms_sucursales — todos los endpoints, ruteados por el API gateway ({{baseUrl}})."
